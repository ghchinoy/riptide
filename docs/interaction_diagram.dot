digraph ComputerUseInteraction {
    rankdir=LR;
    node [shape=box, style=filled, fillcolor=white, fontname="Helvetica"];
    edge [fontname="Helvetica", fontsize=10];
    
    User [shape=ellipse, fillcolor=lightblue, label="User"];
    FileSystem [shape=folder, label="File System\n(screenshots/ & logs/)", fillcolor=lightyellow];
    
    subgraph cluster_App {
        label = "Go Application";
        style=filled;
        fillcolor=lightgrey;
        fontname="Helvetica";
        
        Main [label="Main Entry\n(main.go)"];
        Orchestration [label="Orchestration Loop\n(computer.Run)"];
        Executor [label="Action Executor\n(executor.go)"];
        AimAssist [label="Spatial Aim Assist\n& Shadow DOM", shape=note, fontsize=9];
    }
    
    subgraph cluster_External {
        label = "External Services";
        style=dashed;
        fontname="Helvetica";
        
        Gemini [label="Gemini Model\n(Vertex AI)", shape=hexagon, fillcolor=lavender];
        Chrome [label="Headless Chrome\n(chromedp)", shape=component, fillcolor=lightcyan];
    }
    
    User -> Main [label="Starts App\n(-prompt)"];
    Main -> Chrome [label="Init Browser\n(1280x1024)"];
    Main -> Orchestration [label="Start Loop"];
    
    Orchestration -> Chrome [label="1. Observe State\n(Screenshot + DOM)"];
    Chrome -> Orchestration [label="State Data"];
    Orchestration -> FileSystem [label="2. Save turn_N_post.png\n& turn_N_full.png"];
    
    Orchestration -> Gemini [label="3. GenerateContent\n(History + Screenshot)"];
    Gemini -> Orchestration [label="4. Multi-Part Response\n(Thinking + FunctionCalls)"];
    
    Orchestration -> Executor [label="5. Execute(Action)"];
    Executor -> AimAssist [label="Refine Coords"];
    Executor -> Chrome [label="6. CDP Commands\n(Mouse, Key, Touch)"];
    Chrome -> Executor [label="Action Result"];
    Executor -> Orchestration [label="ToolOutput\n(Success/Error)"];
    
    Orchestration -> Gemini [label="7. FunctionResponse\n(Output + Verification)"];
    
    // Feedback loop
    Gemini -> Orchestration [style=dotted, label="Next Turn"];
}